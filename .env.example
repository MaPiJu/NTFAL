# Optional overrides — nothing here is required and nothing here is a secret.
# This project is READ-ONLY: it never needs (and must never be given) a private
# key, wallet, or exchange API secret.

# Override account equity from config.toml
#EQUITY=10000

# Override risk per trade (fraction; hard-capped at 0.02 regardless)
#RISK_PCT=0.01

# Override the Hyperliquid public info endpoint (e.g. testnet)
#HL_API_URL=https://api.hyperliquid.xyz/info
